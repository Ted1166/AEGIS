{
  "name": "contracts",
  "version": "1.0.0",
  "description": "Aegis — AI-Guarded Stablecoin Vault on Polkadot Hub",
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network westendAssetHub",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network polkadotAssetHub",
    "verify:testnet": "hardhat run scripts/verify.js --network westendAssetHub",
    "seed:testnet": "hardhat run scripts/seed.js --network westendAssetHub",
    "sentinel": "node ai/sentinel/index.js",
    "scorer": "node ai/scorer/index.js",
    "advisor": "node ai/advisor/index.js",
    "deploy:polkadot": "node scripts/deploy-polkadot.js",
    "seed:polkadot": "node scripts/seed-polkadot.js",
    "verify:polkadot": "node scripts/verify-polkadot.js"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@parity/resolc": "^0.6.0",
    "@polkadot/util-crypto": "^14.0.1",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.3",
    "@types/node": "^22.0.0",
    "hardhat": "^3.1.10",
    "typescript": "^5.9.3"
  }
}
